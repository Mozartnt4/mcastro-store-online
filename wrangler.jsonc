{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcastro-store-online",
  "main": "src/index.js",
  "compatibility_date": "2026-07-18",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "observability": { "enabled": true }
}
